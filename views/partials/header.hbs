<header class="site-header">
    <div class="header-inner">
        <a href="/" class="logo">Oyang's Blog</a>
        <nav class="nav">
            <a href="/">首页</a>
            {{#if user}}
                {{#if (or (eq user.role "admin") (eq user.role "vip"))}}
                <a href="/editor">写文章</a>
                {{/if}}
                {{#if (eq user.role "admin")}}
                <a href="/admin">管理</a>
                {{/if}}
            {{/if}}
            <form action="/search" method="GET" class="search-form">
                <input type="text" name="q" placeholder="搜索文章..." title="搜索标题、内容或作者（多词空格分隔=全部命中，不区分大小写）" />
                <button type="submit" aria-label="搜索">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="7"></circle>
                        <line x1="21" y1="21" x2="16.5" y2="16.5"></line>
                    </svg>
                </button>
            </form>
            {{#if user}}
                <div class="user-info">
                    <div class="user-avatar">{{substring user.username 0 1}}</div>
                    <span class="username">{{user.username}}</span>
                    {{#if (eq user.role "admin")}}<span class="role-badge role-admin">管理员</span>
                    {{else if (eq user.role "vip")}}<span class="role-badge role-vip">VIP</span>
                    {{/if}}
                    <a href="/settings" class="settings-link">设置</a>
                </div>
                <form action="/logout" method="POST" class="logout-form">
                    <button type="submit">登出</button>
                </form>
            {{else}}
                <a href="/login">登录</a>
                <a href="/register">注册</a>
            {{/if}}
        </nav>
    </div>
</header>