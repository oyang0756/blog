<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>管理后台 · Oyang的博客</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Noto+Serif+SC:wght@300;400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;1,8..60,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    {{> header}}

    <main class="main-content">
        <div class="admin-page">
            <h1>管理后台</h1>

            <div class="admin-stats">
                <div class="stat-card">
                    <h3>{{userCount}}</h3>
                    <p>用户</p>
                    <a href="/admin/users" class="btn">管 理</a>
                </div>
                <div class="stat-card">
                    <h3>{{postCount}}</h3>
                    <p>文章</p>
                    <a href="/admin/posts" class="btn">管 理</a>
                </div>
                <div class="stat-card">
                    <h3>{{commentCount}}</h3>
                    <p>评论</p>
                    <a href="/admin/comments" class="btn">管 理</a>
                </div>
            </div>

            <div class="admin-nav">
                <a href="/admin/users" class="admin-nav-btn">用户管理</a>
                <a href="/admin/posts" class="admin-nav-btn">文章管理</a>
                <a href="/admin/comments" class="admin-nav-btn">评论管理</a>
                <a href="/admin/import" class="admin-nav-btn">批量导入</a>
            </div>
        </div>
    </main>

    {{> footer}}
</body>
</html>